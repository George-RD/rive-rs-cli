{
  "scene_format_version": 1,
  "artboard": {
    "name": "BlendDemo",
    "width": 400,
    "height": 400,
    "children": [
      {
        "type": "shape",
        "name": "Dot",
        "x": 200,
        "y": 200,
        "children": [
          { "type": "ellipse", "name": "Circle", "width": 100, "height": 100, "origin_x": 0.5, "origin_y": 0.5 },
          { "type": "fill", "name": "DotFill", "children": [
            { "type": "solid_color", "name": "Blue", "color": "#0000FF" }
          ]}
        ]
      }
    ],
    "animations": [
      {
        "name": "anim_a",
        "fps": 60,
        "duration": 60,
        "keyframes": [
          {
            "object": "Dot",
            "property": "x",
            "frames": [
              { "frame": 0, "value": 100.0 },
              { "frame": 59, "value": 300.0 }
            ]
          }
        ]
      },
      {
        "name": "anim_b",
        "fps": 60,
        "duration": 60,
        "keyframes": [
          {
            "object": "Dot",
            "property": "y",
            "frames": [
              { "frame": 0, "value": 100.0 },
              { "frame": 59, "value": 300.0 }
            ]
          }
        ]
      }
    ],
    "state_machines": [
      {
        "name": "BlendMachine",
        "inputs": [
          { "type": "number", "name": "mix", "value": 0.5 }
        ],
        "layers": [
          {
            "states": [
              { "type": "entry" },
              { "type": "blend_state_1d", "input_id": 0, "children": [
                { "type": "blend_animation_1d", "animation_id": 0, "value": 0.0 },
                { "type": "blend_animation_1d", "animation_id": 1, "value": 1.0 }
              ]},
              { "type": "exit" }
            ],
            "transitions": [
              { "from": 0, "to": 1 }
            ]
          },
          {
            "states": [
              { "type": "entry" },
              { "type": "blend_state_direct", "children": [
                { "type": "blend_animation_direct", "animation_id": 1, "input_id": 0, "mix_value": 0.5, "blend_source": 1 }
              ]},
              { "type": "exit" }
            ],
            "transitions": [
              { "from": 0, "to": 1 }
            ]
          }
        ]
      }
    ]
  }
}
