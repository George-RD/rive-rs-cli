{
  "scene_format_version": 1,
  "artboard": {
    "name": "ComparatorDemo",
    "width": 400,
    "height": 400,
    "children": [
      {
        "type": "shape",
        "name": "Box",
        "x": 200,
        "y": 200,
        "children": [
          { "type": "rectangle", "name": "Rect", "width": 100, "height": 100, "origin_x": 0.5, "origin_y": 0.5 },
          { "type": "fill", "name": "BoxFill", "children": [
            { "type": "solid_color", "name": "Green", "color": "#00FF00" }
          ]}
        ]
      }
    ],
    "animations": [
      {
        "name": "idle",
        "fps": 60,
        "duration": 60,
        "keyframes": [
          {
            "object": "Box",
            "property": "x",
            "frames": [
              { "frame": 0, "value": 200.0 },
              { "frame": 59, "value": 200.0 }
            ]
          }
        ]
      },
      {
        "name": "active",
        "fps": 60,
        "duration": 60,
        "keyframes": [
          {
            "object": "Box",
            "property": "x",
            "frames": [
              { "frame": 0, "value": 200.0 },
              { "frame": 59, "value": 300.0 }
            ]
          }
        ]
      }
    ],
    "state_machines": [
      {
        "name": "Logic",
        "inputs": [
          { "type": "bool", "name": "isActive", "value": false },
          { "type": "number", "name": "threshold", "value": 0.0 }
        ],
        "layers": [
          {
            "states": [
              { "type": "entry" },
              { "type": "animation", "animation": "idle" },
              { "type": "animation", "animation": "active" },
              { "type": "exit" }
            ],
            "transitions": [
              { "from": 0, "to": 1 },
              {
                "from": 1,
                "to": 2,
                "conditions": [
                  { "input": "isActive", "value": true }
                ],
                "children": [
                  { "type": "transition_value_boolean_comparator", "value": true },
                  { "type": "transition_value_number_comparator", "value": 1.0 },
                  { "type": "transition_value_string_comparator", "value": "on" },
                  { "type": "transition_value_color_comparator", "value": "#FF0000" }
                ]
              },
              {
                "from": 2,
                "to": 1,
                "conditions": [
                  { "input": "isActive", "value": false }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
